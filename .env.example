# =============================================================================
# YCare HMS — infra/.env
# -----------------------------------------------------------------------------
# Copy to .env and edit. This file is loaded by docker compose for any vars
# referenced via ${VAR} interpolation in docker-compose.yml.
#
# Per-service env (Next.js module toggles, AWS keys, etc.) lives in
# hms-app/.env — that file is passed via env_file: to the hms-app container.
# =============================================================================

# Postgres — must match the credentials in docker-compose.yml.
POSTGRES_USER=admin
POSTGRES_PASSWORD=testtest
POSTGRES_DB=ycare_hms_dev
